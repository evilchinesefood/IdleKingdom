# IdleKingdom — static hosting config (Apache)

# PascalCase entry file: Apache's default DirectoryIndex is lowercase-only,
# so a bare /kingdom/ would 403 without this.
<IfModule mod_dir.c>
  DirectoryIndex Index.html index.html
</IfModule>

# Correct MIME types for native ES modules + PWA assets.
<IfModule mod_mime.c>
  AddType text/javascript .js
  AddType text/javascript .mjs
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
</IfModule>

# Always revalidate the service worker so updates ship promptly,
# plus baseline security headers.
<IfModule mod_headers.c>
  <FilesMatch "ServiceWorker\.js$">
    Header set Cache-Control "no-cache, max-age=0"
  </FilesMatch>
  Header set X-Content-Type-Options nosniff
  Header set Referrer-Policy no-referrer
</IfModule>

# Deny direct access to dotfiles (.htaccess, .npmrc, .git, etc.) — but never
# /.well-known/ (ACME renewals, PWA assetlinks live there by web standard).
RedirectMatch 404 "/\.(?!well-known/)"

# Clean path-based routing (no #): serve the SPA shell for the known client routes
# so a deep link / refresh to /kingdom/factory loads Index.html (the router then
# reads the path). Real files/dirs (assets) are served normally.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /kingdom/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # route list — keep in sync with Router.ROUTES + the inline <base> script in Index.html.
  # The dead expeditions|heroes paths are kept deliberately: a stale client's deep link
  # still loads the SPA shell (the router then clamps the unknown route -> factory).
  RewriteRule ^(factory|research|war|expeditions|heroes)/?$ Index.html [L]
</IfModule>
