# IdleKingdom — static hosting config (Apache)

# PascalCase entry file: Apache's default DirectoryIndex is lowercase-only,
# so a bare /kingdom/ would 403 without this.
<IfModule mod_dir.c>
  DirectoryIndex Index.html index.html
</IfModule>

# Correct MIME types for native ES modules + PWA assets.
<IfModule mod_mime.c>
  AddType text/javascript .js
  AddType text/javascript .mjs
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
</IfModule>

# Always revalidate the service worker so updates ship promptly.
<IfModule mod_headers.c>
  <FilesMatch "ServiceWorker\.js$">
    Header set Cache-Control "no-cache, max-age=0"
  </FilesMatch>
</IfModule>

# Clean path-based routing (no #): serve the SPA shell for the known client routes
# so a deep link / refresh to /kingdom/factory loads Index.html (the router then
# reads the path). Real files/dirs (assets) are served normally.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /kingdom/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # route list — keep in sync with Router.ROUTES + the inline <base> script in Index.html
  RewriteRule ^(factory|research|expeditions|heroes)/?$ Index.html [L]
</IfModule>
